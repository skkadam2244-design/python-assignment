class Library:

    def __init__(self):
        self.book1 = "Python"
        self.book2 = "C"
        self.book3 = "Java"
      

    def show_books(self):
        print("Available Books:")
        print(self.book1)
        print(self.book2)
        print(self.book3)
      

    def issue_book(self):

        print("Python issued")
        self.book1 = "Issued"

    def return_book(self):

        print("Python returned")
        self.book1 = "Python"



obj = Library()
obj.show_books()
obj.issue_book()
obj.show_books()
obj.return_book()
obj.show_books()
